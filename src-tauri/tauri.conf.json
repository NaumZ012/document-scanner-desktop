{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Invoice Scanner",
  "version": "1.0.0",
  "identifier": "com.invoice-scanner.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost https://asset.localhost; frame-src 'self' asset: http://asset.localhost https://asset.localhost; object-src 'self' asset: http://asset.localhost https://asset.localhost",
      "assetProtocol": { "enable": true, "scope": ["**"] }
    },
    "windows": [
      {
        "label": "main",
        "title": "Invoice Scanner",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "shadow": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "createUpdaterArtifacts": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "windows": { "certificateThumbprint": null, "digestAlgorithm": "sha256", "timestampUrl": "" },
    "longDescription": "Scan invoices and export to Excel.",
    "shortDescription": "Invoice Scanner",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "resources": [],
    "externalBin": [],
    "copyright": "Copyright (c) 2025",
    "category": "Productivity"
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYyNkUzQTcwRjNBMTEwMkYKUldRdkVLSHpjRHB1WWtISSs2SU13SzlianFKTXZ5c0RRTDV1TTNqWHRrR3lmd1F1THhpRWN1ZVUK",
      "endpoints": ["https://github.com/REPLACE_ME/REPLACE_ME/releases/latest/download/latest.json"],
      "windows": { "installMode": "passive" }
    }
  }
}
